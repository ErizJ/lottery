[server]
app_mode  = "debug"          # debug | release
http_port = ":3000"
jwt_key   = "your-secret-key"

[mysql]
db_host     = "127.0.0.1"
db_port     = "3306"
db_user     = "root"
db_password = "your-password"
db_name     = "lottery"

[redis]
addr = "127.0.0.1:6379"
db   = 0

[kafka]
addr  = "127.0.0.1:9092"
topic = "order"
